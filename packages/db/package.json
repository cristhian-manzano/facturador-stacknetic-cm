{
  "name": "@facturador/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./test-harness": {
      "types": "./dist/test-harness.d.ts",
      "import": "./dist/test-harness.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "dotenv -e ../../.env -- vitest run --passWithNoTests",
    "test:coverage": "dotenv -e ../../.env -- vitest run --coverage --passWithNoTests",
    "clean": "rm -rf dist",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev --name init",
    "prisma:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:migrate:status": "dotenv -e ../../.env -- prisma migrate status",
    "prisma:validate": "dotenv -e ../../.env -- prisma validate",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "argon2": "0.41.1",
    "ulid": "2.3.0"
  },
  "devDependencies": {
    "@facturador/config": "workspace:*",
    "@types/node": "22.9.0",
    "@vitest/coverage-v8": "2.1.4",
    "dotenv-cli": "7.4.2",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "vitest": "2.1.4"
  }
}
