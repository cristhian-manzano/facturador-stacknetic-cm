# Facturador monorepo pnpm settings.
#
# - `node-linker=isolated` (the pnpm default) keeps the strict, symlinked
#   `node_modules` layout that surfaces missing dependency declarations
#   early. We intentionally do NOT set `node-linker=hoisted` because that
#   would mask undeclared deps and erode the workspace boundary checks the
#   ESLint config enforces (see `eslint.config.js` `no-restricted-imports`).
# - `engine-strict=true` forces a failing install on Node engines outside
#   the `engines` window declared in the root `package.json` (Node 22).
#   Without it, contributors on Node 20 / 23 silently produce a divergent
#   lockfile or break native modules at runtime.
# - `auto-install-peers=true` is the modern pnpm default; pinning it here
#   keeps the behaviour explicit for tooling that reads the file directly.
# - `prefer-workspace-packages=true` ensures workspace-internal deps
#   (`@facturador/*`) always resolve to the local source, never the
#   registry, even if a published version somehow shares the name.

engine-strict=true
auto-install-peers=true
prefer-workspace-packages=true
