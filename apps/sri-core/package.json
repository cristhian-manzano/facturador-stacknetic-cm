{
  "name": "@facturador/sri-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "tsx scripts/copy-schemas.ts",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node scripts/copy-resources.mjs",
    "predev": "tsx scripts/copy-schemas.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "pretest": "tsx scripts/copy-schemas.ts",
    "test": "dotenv -e ../../.env -- vitest run --passWithNoTests",
    "test:coverage": "dotenv -e ../../.env -- vitest run --coverage --passWithNoTests",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "node dist/index.js",
    "poll:once": "dotenv -e ../../.env -- tsx src/jobs/worker.ts once",
    "poll:forever": "dotenv -e ../../.env -- tsx src/jobs/worker.ts forever",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@facturador/contracts": "workspace:*",
    "@facturador/db": "workspace:*",
    "@facturador/logger": "workspace:*",
    "@facturador/utils": "workspace:*",
    "@xmldom/xmldom": "0.8.13",
    "express": "5.0.1",
    "lru-cache": "11.0.2",
    "multer": "2.0.1",
    "node-cron": "3.0.3",
    "node-forge": "1.3.1",
    "ulid": "2.3.0",
    "undici": "6.21.0",
    "xadesjs": "2.6.7",
    "xml-core": "1.2.5",
    "xmldsigjs": "2.8.7",
    "xmllint-wasm": "4.0.2",
    "xpath": "0.0.34",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@facturador/config": "workspace:*",
    "@types/express": "5.0.0",
    "@types/multer": "1.4.12",
    "@types/node": "22.9.0",
    "@types/node-cron": "3.0.11",
    "@types/node-forge": "1.3.11",
    "@types/supertest": "6.0.2",
    "@vitest/coverage-v8": "2.1.4",
    "dotenv-cli": "7.4.2",
    "jose": "5.9.6",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "vitest": "2.1.4"
  }
}
