{
  "name": "@facturador/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "dotenv -e ../../.env -- vitest run",
    "test:coverage": "dotenv -e ../../.env -- vitest run --coverage",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@facturador/contracts": "workspace:*",
    "@facturador/db": "workspace:*",
    "@facturador/logger": "workspace:*",
    "@facturador/utils": "workspace:*",
    "argon2": "0.41.1",
    "cookie-parser": "1.4.7",
    "decimal.js": "10.4.3",
    "express": "5.0.1",
    "express-rate-limit": "7.4.0",
    "node-cron": "3.0.3",
    "ulid": "2.3.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@facturador/config": "workspace:*",
    "@types/cookie-parser": "1.4.7",
    "@types/express": "5.0.0",
    "@types/node": "22.9.0",
    "@types/node-cron": "3.0.11",
    "@types/supertest": "6.0.2",
    "@vitest/coverage-v8": "2.1.4",
    "dotenv-cli": "7.4.2",
    "fast-check": "3.23.1",
    "msw": "2.6.4",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "vitest": "2.1.4"
  }
}
