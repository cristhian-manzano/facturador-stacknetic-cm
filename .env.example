# =============================================================================
# .env.example — Facturador SRI Ecuador
# -----------------------------------------------------------------------------
# Canonical list of every environment variable required by the stack.
# Copy to `.env` and adjust for your local environment:
#   cp .env.example .env
# `.env` is git-ignored (see /.gitignore). DO NOT commit real secrets.
# Placeholders prefixed with `change_me_` MUST be replaced for any use
# beyond a throwaway local stack.
# Source of truth: ai/specs/0003-docker-and-local-dev.md §6.2.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
# Node runtime environment. One of: development | test | production.
NODE_ENV=development
# Pino log level. One of: fatal | error | warn | info | debug | trace.
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
# Database superuser used by the `db` service for local development.
POSTGRES_USER=facturador
# Password for POSTGRES_USER. Local-only placeholder — replace in any shared env.
POSTGRES_PASSWORD=facturador
# Default database name created on first boot.
POSTGRES_DB=facturador
# Host-side port published by the `db` service. Change if 5432 is taken.
POSTGRES_PORT=5432
# Connection URL used when running tooling FROM THE HOST WORKSTATION
# (prisma migrate, prisma db seed, vitest integration). Reaches the
# compose-published port on `localhost`.
# In-container services (api, sri-core) receive an override
# (`postgresql://...@db:5432/...`) via docker-compose `environment:`.
DATABASE_URL=postgresql://facturador:facturador@localhost:5432/facturador?schema=public

# -----------------------------------------------------------------------------
# API service (apps/api)
# -----------------------------------------------------------------------------
# Port the Express API listens on inside the container; also the host-published port.
API_PORT=3000
# Externally reachable API URL. Used by CORS, links in emails, etc.
API_PUBLIC_URL=http://localhost:3000
# Session cookie name. Production overrides to `__Host-facturador_session`
# (only valid when served over HTTPS); dev uses the plain prefix.
SESSION_COOKIE_NAME=facturador_session
# Session signing secret. 32+ bytes of entropy. Placeholder — rotate before any deploy.
SESSION_COOKIE_SECRET=change_me_session_secret_min_32_bytes_dev_only_______
# CSRF double-submit cookie name. Production overrides to `__Host-facturador_csrf`.
CSRF_COOKIE_NAME=facturador_csrf
# Maximum session lifetime in minutes (8 hours = 480).
SESSION_TTL_MIN=480
# Comma-separated list of origins allowed by CORS. Dev includes the Vite host.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# SRI Core service (apps/sri-core)
# -----------------------------------------------------------------------------
# Port the SRI Core service listens on inside the container.
SRI_CORE_PORT=3100
# Externally reachable URL for SRI Core (only API talks to it directly).
SRI_CORE_PUBLIC_URL=http://localhost:3100
# Shared secret used to mint service-to-service tokens between API and SRI Core.
# 32+ bytes of entropy. Placeholder — rotate before any deploy.
SRI_CORE_SERVICE_TOKEN_SECRET=change_me_service_token_secret_min_32_bytes_dev___
# AES-256 master key used to encrypt .p12 certificate blobs at rest in dev only.
# 64 lowercase hex characters (= 32 bytes). Production sources this from KMS.
SRI_CERT_MASTER_KEY_HEX=change_me_to_64_lowercase_hex_chars__________________________dev
# Default SRI ambiente: 1 = pruebas (sandbox), 2 = producción.
SRI_AMBIENTE_DEFAULT=1
# SRI SOAP endpoints for the PRUEBAS (sandbox) ambiente.
SRI_RECEPCION_URL_PRUEBAS=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
SRI_AUTORIZACION_URL_PRUEBAS=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl
# SRI SOAP endpoints for the PRODUCCION ambiente.
SRI_RECEPCION_URL_PRODUCCION=https://cel.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
SRI_AUTORIZACION_URL_PRODUCCION=https://cel.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl
# HTTP timeout in milliseconds for outgoing SRI SOAP calls.
SRI_HTTP_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Service auth (JWT between internal services)
# -----------------------------------------------------------------------------
# 256-bit secret used by API <-> SRI Core HS256 JWTs. ≥ 32 chars of entropy.
# Placeholder — rotate before any deploy.
SERVICE_JWT_SECRET=change_me_base64_256_bit_service_jwt_secret_dev_only___
# Base URL of the SRI-Core service as seen from the API. In compose this is
# the in-network hostname; from the host workstation it's localhost.
SRI_CORE_URL=http://sri-core:3100
# Stub mode for SRI Core. "true" short-circuits POST /v1/documents/emit to
# AUTORIZADO so api/web can iterate without the full SOAP pipeline
# (SPEC-0020 §3 / PROMPT-0020 §6). NEVER set "true" when NODE_ENV=production
# — the env validator refuses to boot the service in that combo.
SRI_STUB_MODE=true
# When "true" the api's `/readyz` issues a best-effort `GET /healthz` against
# sri-core (with a 1.5 s timeout) and reports 503 if sri-core is unreachable.
# Default "false" keeps tests and local dev decoupled from sri-core's state.
READYZ_PING_SRI_CORE=false

# -----------------------------------------------------------------------------
# SRI Core — document lifecycle (SPEC-0026)
# -----------------------------------------------------------------------------
# Filesystem root for the dev BlobStore (signed/authorized XML payloads).
# Absolute or relative to process.cwd(). `.blobs/` is .gitignored at the
# repo root because the contents may include customer PII.
SRI_BLOB_FS_ROOT=./.blobs
# Polling job (SPEC-0026 §FR-5). Cron expression governs when the worker
# scans EN_PROCESO documents. Batch size caps how many docs per tick.
# Sleep between docs gives SRI a breather; the orchestrator enforces a
# hard total deadline (in milliseconds) per document before leaving it in
# EN_PROCESO for operator intervention.
SRI_POLL_CRON=*/2 * * * *
SRI_POLL_BATCH_SIZE=50
SRI_POLL_SLEEP_BETWEEN_DOCS_MS=1000
SRI_POLL_MAX_BACKOFF_MS=600000
SRI_POLL_TOTAL_DEADLINE_MS=300000

# -----------------------------------------------------------------------------
# Mail (dev SMTP catcher: Mailpit — modern replacement for the abandoned
# MailHog; same protocol surface, multi-arch image, active maintenance).
# -----------------------------------------------------------------------------
# SMTP host as seen from inside the docker network.
SMTP_HOST=mailpit
# SMTP port (Mailpit default).
SMTP_PORT=1025

# -----------------------------------------------------------------------------
# Web app (apps/web — Vite)
# -----------------------------------------------------------------------------
# Host-published port for the Vite dev server.
WEB_PORT=5173
# Base URL the browser uses to reach the API. Must be reachable from the host browser,
# NOT from inside the container network.
VITE_API_BASE_URL=http://localhost:3000
